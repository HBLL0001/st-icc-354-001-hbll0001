# ============================================================
# Environment Variables for Docker Compose – Mockup API Server
# ============================================================

# ─── App ─────────────────────────────────────────────────────
APP_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# ─── Database (PostgreSQL) ──────────────────────────────────
POSTGRES_DB=mockdb
POSTGRES_USER=mockuser
POSTGRES_PASSWORD=mockpass123
DB_HOST=db
DB_PORT=5432

# ─── pgAdmin ────────────────────────────────────────────────
PGADMIN_PORT=8082
PGADMIN_DEFAULT_EMAIL=admin@mock.local
PGADMIN_DEFAULT_PASSWORD=admin123

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=bW9ja3VwLWFwaS1zZXJ2ZXItc2VjcmV0LWtleS0yNTZiaXRzLWxvbmcx

# ─── Volume path on host ────────────────────────────────────
DB_VOLUME_PATH=./data/postgres
